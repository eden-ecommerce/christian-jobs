# Private Eden GitHub Packages registry for @eden-ecommerce/* packages
# (e.g. @eden-ecommerce/blog-kit). Requires NPM_GITHUB_TOKEN (a GitHub PAT with
# read:packages) to be set in the environment during install.
@eden-ecommerce:registry=https://npm.pkg.github.com
//npm.pkg.github.com/:_authToken=${NPM_GITHUB_TOKEN}

# Sentry/OTel instrumentation: hoist hook packages for Turbopack resolution (pnpm).
public-hoist-pattern[]=*import-in-the-middle*
public-hoist-pattern[]=*require-in-the-middle*

# Private Eden GitLab registry for @christian-360/* packages.
# TEMPORARILY DISABLED: the registry is unreachable from the v0 sandbox and
# requires an NPM_TOKEN, which blocks `pnpm install` and the preview.
# Re-enable (and ensure NPM_TOKEN is set) when wiring the real packages back in.
# @christian-360:registry=https://git.eden.co.uk/api/v4/projects/50/packages/npm/
# //git.eden.co.uk/api/v4/projects/50/packages/npm/:_authToken="${NPM_TOKEN}"
