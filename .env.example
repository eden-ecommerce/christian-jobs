# Copy to .env for local development. Never commit .env.
#
# Deploy config: NEXT_PUBLIC_* below (also in constants/app.ts).
# Read server secrets via getServerEnv() from @eden-ecommerce/lib/env-server — never NEXT_PUBLIC_* for secrets.
#
# Requires GITHUB_TOKEN in your shell for `pnpm install` (GitHub Packages auth).

# ---------------------------------------------------
# Private secrets and variables for server-side usage
# ---------------------------------------------------

# API_SECRET_KEY=
# WEBHOOK_SIGNING_SECRET=
# API_KEY=                          # /api/revalidate — x-api-key header
# SANITY_PREVIEW_TOKEN=             # /api/preview — enables draft mode
# EDEN_PAYMENT_CLIENT_ID=
# EDEN_PAYMENT_CLIENT_SECRET=

# Sanity GROQ (server-only — @eden-ecommerce/lib/sanity/direct-fetch)
# EDEN_SANITY_PROJECT_ID=
# EDEN_SANITY_DATASET=
# EDEN_SANITY_API_DEVELOPER_TOKEN=

# ------------------------------------
# Public variables for use client-side
# ------------------------------------

# Deploy config (required — constants/app.ts throws if unset in production builds)
NEXT_PUBLIC_PRODUCTION_ORIGIN=https://www.eden.co.uk
# NEXT_PUBLIC_DEV_ORIGIN=http://localhost:3000  # optional — omit for same-origin dev
NEXT_PUBLIC_NAMESPACE=christian-jobs

# Eden API (CMS + platform)
# NEXT_PUBLIC_EDEN_API_URL=
# NEXT_PUBLIC_EDEN_OAUTH_URL=
# NEXT_PUBLIC_EDEN_HUB_ORIGIN=

# Algolia (search-only keys — safe in browser)
# NEXT_PUBLIC_ALGOLIA_APP_ID=
# NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=

# Google Maps (browser API key — restrict by HTTP referrer in Google Cloud Console)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Google Tag Manager (public — omit to disable GTM bootstrap)
# NEXT_PUBLIC_GOOGLE_TAG_MANAGER_ID=GTM-XXXXXXX

# Sanity image CDN
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=
# NEXT_PUBLIC_SANITY_PROJECT_SET=

# Optional
# NEXT_PUBLIC_IMAGE_OPTIMISATION_URL=
# NEXT_PUBLIC_DESIGN_SYSTEM=

# Sentry (error monitoring)
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_DATASET=eden-test
# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# Vercel deployment (set in Vercel project settings — not required for local dev)
# GITHUB_TOKEN=                     # read:packages — install @eden-ecommerce/common and lib from GitHub Packages

# Sandbox access (Vercel origin only — /sandbox/* routes)
# SANDBOX_ACCESS=public             # or eden-user (requires Eden session on Vercel)
